# Neutralize Cloudflare CDN for 64PE entirely.
# Cloudflare caused 10+ incidents / 15-25h debugging time (2026-01 ~ 2026-03).
# SW Cache API handles offline caching independently — CDN cache is redundant.
# no-cache on ALL files = Cloudflare becomes pass-through.
<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</IfModule>

# Clear old SW caches on visit. Safe: does NOT clear localStorage.
<Files "index.html">
    Header set Clear-Site-Data "\"cache\""
</Files>
